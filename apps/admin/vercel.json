{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "framework": "nextjs",
    "cleanUrls": true,
    "headers": [
        {
            "source": "/logo.png",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=86400, stale-while-revalidate=604800"
                }
            ]
        },
        {
            "source": "/_next/static/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ],
    "crons": [
        { "path": "/api/auto-blog?type=3d", "schedule": "0 8 * * *" },
        { "path": "/api/auto-blog?type=3d", "schedule": "0 14 * * *" },
        { "path": "/api/auto-blog?type=aksesuar", "schedule": "0 11 * * *" },
        { "path": "/api/auto-blog?type=otopark", "schedule": "0 17 * * *" }
    ]
}